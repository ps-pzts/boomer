# ── Boomer environment variables ──────────────────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# ── Paths ─────────────────────────────────────────────────────────────────────
BOOMER_DB_PATH=./data/boomer.db
BOOMER_ARCHIVE_DIR=./data/archive
BOOMER_BACKUP_DIR=./data/backups

# ── Kite Connect (Zerodha) ────────────────────────────────────────────────────
# Get from https://developers.kite.trade/
# Refresh KITE_ACCESS_TOKEN each morning with: python scripts/kite_login.py
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ── Fyers ─────────────────────────────────────────────────────────────────────
# Get from https://myapi.fyers.in/
# Refresh FYERS_ACCESS_TOKEN each morning with: python scripts/fyers_login.py
FYERS_CLIENT_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=https://127.0.0.1/
FYERS_ACCESS_TOKEN=

# ── Telegram alerts ───────────────────────────────────────────────────────────
# Create a bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email alerts (optional — uses Gmail SMTP as example) ──────────────────────
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── Dashboard auth ────────────────────────────────────────────────────────────
BASIC_AUTH_USER=boomer
BASIC_AUTH_PASSWORD=changeme
